# TH-Platform Gateway — environment variables.
# Copy to `.env` for local dev; in production use systemd EnvironmentFile.

# Service
TH_BIND_ADDR=0.0.0.0:8080
TH_ENV=development                 # development | staging | production
TH_LOG_LEVEL=debug

# Postgres
TH_PG_DSN=postgres://th:th@localhost:5432/thplatform?sslmode=disable

# Redis
TH_REDIS_ADDR=localhost:6379
TH_REDIS_PASSWORD=
TH_REDIS_DB=0

# JWT
# Generate with: openssl genrsa -out jwt.pem 2048 && openssl rsa -in jwt.pem -pubout -out jwt.pub
TH_JWT_PRIVATE_KEY_PATH=./keys/jwt.pem
TH_JWT_PUBLIC_KEY_PATH=./keys/jwt.pub
TH_JWT_ACCESS_TTL=15m
TH_JWT_REFRESH_TTL=720h            # 30 days

# Email (verification + password reset)
# For dev you can use Mailpit (localhost:1025) or leave unset to log to console.
TH_SMTP_HOST=
TH_SMTP_PORT=587
TH_SMTP_USER=
TH_SMTP_PASS=
TH_SMTP_FROM=noreply@th-platform.example.com

# OAuth — leave blank to disable that provider
TH_OAUTH_GITHUB_CLIENT_ID=
TH_OAUTH_GITHUB_CLIENT_SECRET=
TH_OAUTH_DISCORD_CLIENT_ID=
TH_OAUTH_DISCORD_CLIENT_SECRET=
TH_OAUTH_QQ_APP_ID=
TH_OAUTH_QQ_APP_KEY=

# Relay
TH_RELAY_PUBLIC_HOSTS=relay-cn.th-platform.example.com:3478

# CORS (dev only — prod restricts to app scheme)
TH_CORS_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost
